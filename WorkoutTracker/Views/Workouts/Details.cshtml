@model WorkoutTracker.Models.WorkoutModel

@{
    ViewData["Title"] = "Ditt träningspass";
    bool isCardio = Model.WorkoutExercises.Any() &&
    Model.WorkoutExercises.First().Weight == null &&
    Model.WorkoutExercises.First().Reps == null;
}

<div class="row mt-4">
    <div class="d-flex mb-2">
        <a asp-action="Index" class="btn btn-outline-dark"><i class="bi bi-arrow-left"></i> Tillbaka</a>
    </div>

    <div class="mt-3">
        <section class="card shadow-sm mb-4">
            <div class="card-body p-4">
                <h1 class="text-center">@Html.DisplayFor(model => model.WorkoutType!.Name)</h1>

                <p>
                    <i class="bi bi-calendar3"></i> @Model.Date.ToString("d MMMM yyyy")
                </p>
                <p>
                    <i class="bi bi-clock"></i> @Html.DisplayFor(model => model.Duration) min
                </p>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <p>
                        <i class="bi bi-chat-right-text"></i> @Html.DisplayFor(model => model.Notes)
                    </p>
                }

                @if (Model.WorkoutExercises == null || !Model.WorkoutExercises.Any())
                {
                    <p class="text-muted">Det finns inga övningar registrerade för detta pass.</p>
                }
                else if (isCardio)
                {
                    @* Layout för mobil *@
                    <div class="d-md-none">
                        @foreach (var exercise in Model.WorkoutExercises)
                        {
                            <div class="card mb-2 shadow-sm p-2">
                                <div class="fw-semibold">@exercise.Exercise?.Name</div>
                                <small class="text-muted">
                                    @if (exercise.Distance.HasValue)
                                    {
                                        <span>@exercise.Distance km</span>
                                    }
                                    @if (!string.IsNullOrEmpty(exercise.ExerciseDetails))
                                    {
                                        <span> -
                                            @exercise.ExerciseDetails</span>
                                    }
                                </small>
                            </div>
                        }
                    </div>

                    @* Layout för större skärmar *@
                    <table class="table table-hover d-none d-md-table">
                        <thead>
                            <tr>
                                <th>Övning</th>
                                <th>Distans (km)</th>
                                <th>Detaljer</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var exercise in Model.WorkoutExercises)
                            {
                                <tr>
                                    <td>@exercise.Exercise?.Name</td>
                                    <td>@exercise.Distance</td>
                                    <td>@exercise.ExerciseDetails</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    @* Layout för mobil *@
                    <div class="d-md-none">
                        @foreach (var exercise in Model.WorkoutExercises)
                        {
                            <div class="card mb-2 shadow-sm">
                                <div class="card-body py-2">
                                    <div class="fw-semibold">@exercise.Exercise?.Name</div>
                                    <small class="text-muted">
                                        @exercise.Sets set - @exercise.Reps reps - @exercise.Weight kg
                                    </small>
                                </div>
                            </div>
                        }
                    </div>

                    @* Layout för större skärmar *@
                    <table class="table table-hover d-none d-md-table">
                        <thead>
                            <tr>
                                <th>Övning</th>
                                <th>Set</th>
                                <th>Reps</th>
                                <th>Vikt (kg)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var exercise in Model.WorkoutExercises)
                            {
                                <tr>
                                    <td>@exercise.Exercise?.Name</td>
                                    <td>@exercise.Sets</td>
                                    <td>@exercise.Reps</td>
                                    <td>@exercise.Weight</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                <div class="d-flex justify-content-end mt-3">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-dark px-3 mx-1"><i
                            class="bi bi-pencil"></i> Ändra</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger px-3 mx-1"><i
                            class="bi bi-trash"></i> Ta bort</a>
                </div>
            </div>
        </section>

        <div class="d-flex justify-content-center">
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Lägg till nytt pass</a>
        </div>
    </div>
</div>
