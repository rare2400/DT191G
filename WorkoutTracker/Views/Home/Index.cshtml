@{
    ViewData["Title"] = "Hem";
    var lastWorkout = ViewBag.LastWorkout as WorkoutTracker.Models.WorkoutModel;
    int totalWorkouts = ViewBag.TotalWorkouts ?? 0;
    int thisMonth = ViewBag.ThisMonth ?? 0;
}

@if (User.Identity?.IsAuthenticated == true)
{
    @* Hero med välkomsthälsning *@
    <div class="hero">
    <div style="flex: 1 1 280px">
        <p class="hero-eyebrow">Din träning. Din data.</p>
        <h1 class="hero-title">Välkommen tillbaka,<br><span class="hero-title-accent">@ViewBag.FirstName!</span></h1>
        <p class="hero-sub">Här är en översikt över din träning.</p>
        <a asp-controller="Workouts" asp-action="Create" class="btn btn-primary btn-lg px-4">
            <i class="bi bi-plus-lg"></i> Nytt pass
        </a>
    </div>
    <div class="stat-cards d-flex flex-wrap gap-2">
        <div class="card text-center p-4">
            <h2 class="fs-1 fw-bold mb-1">@totalWorkouts</h2>
            <p class="text-uppercase letter-spacing-wide mb-0 small">pass totalt</p>
        </div>
        <div class="card text-center p-4">
            <h2 class="fs-1 fw-bold mb-1">@thisMonth</h2>
            <p class="text-uppercase letter-spacing-wide mb-0 small">pass denna månad</p>
        </div>
        @if (lastWorkout != null)
            {
                <div class="col-12 col-md-12 mb-3 workout-card-col">
                    <section class="card shadow-sm h-100 p-4">
                        <div class="text-muted small mb-1">Senaste pass</div>
                        <h2 class="fw-semibold fs-4">@lastWorkout.WorkoutType?.Name</h2>
                        <div class="flex-grow-1">
                            <p class="mb-1 small"><i class="bi bi-calendar3"></i> @lastWorkout.Date.ToString("dd MMMM yyyy")</p>
                            <p class="my-1 small"><i class="bi bi-clock"></i> @lastWorkout.Duration min</p>
                            <a asp-controller="Workouts" asp-action="Details" asp-route-id="@lastWorkout.Id"
                                class="btn btn-sm btn-outline-dark mt-2 align-self-start">Visa pass</a>
                        </div>
                    </section>
                </div>
            }
        </div>
    </div>

    @* Snabbnavigation *@
    <p class="text-muted small text-uppercase letter-spacing-wide fw-semibold mb-2">Snabbnavigation</p>
    <div class="row g-3">
    <div class="col-6 col-md-3">
        <a asp-controller="Workouts" asp-action="Create"
            class="card shadow-sm p-4 h-100 text-decoration-none text-dark d-flex flex-column align-items-center justify-content-center workout-card">
            <i class="bi bi-plus-lg fs-2 mb-2"></i>
            <span class="fw-semibold">Nytt pass</span>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Workouts" asp-action="Index"
            class="card shadow-sm p-4 h-100 text-decoration-none text-dark d-flex flex-column align-items-center justify-content-center workout-card">
            <i class="bi bi-journal-text fs-2 mb-2"></i>
            <span class="fw-semibold">Mina pass</span>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="WorkoutExercise" asp-action="Index"
            class="card shadow-sm p-4 h-100 text-decoration-none text-dark d-flex flex-column align-items-center justify-content-center workout-card">
            <i class="bi bi-graph-up-arrow fs-2 mb-2"></i>
            <span class="fw-semibold">Min historik</span>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Exercise" asp-action="Index"
            class="card shadow-sm p-4 h-100 text-decoration-none text-dark d-flex flex-column align-items-center justify-content-center workout-card">
            <i class="bi bi-lightning-charge fs-2 mb-2"></i>
            <span class="fw-semibold">Övningar</span>
        </a>
    </div>
</div>
}
else
{
    @* Hero *@
    <section class="hero">
    <div style="flex: 1 1 280px">
        <p class="hero-eyebrow">Din träning. Din data.</p>
        <h1 class="hero-title">Spåra varje<br><span class="hero-title-accent">lyft & löprunda.</span></h1>
        <p class="hero-sub">Registrera dina pass, se hur din styrka växer och håll koll på varje träning — allt på ett
            ställe.</p>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary btn-lg px-4" asp-area="Identity" asp-page="/Account/Register">Kom igång gratis</a>
            <a class="btn btn-outline-dark btn-lg px-4" asp-area="Identity" asp-page="/Account/Login">Logga in</a>
        </div>
    </div>

    <section class="card pass-preview shadow-sm h-100 p-4" aria-hidden="true">
        <p class="text-muted small mb-1">Senaste pass</p>
        <h2 class="fw-semibold fs-4">Styrketräning</h2>
        <div class="flex-grow-1">
            <p class="mb-2 small"><i class="bi bi-calendar3"></i> 8 mars 2026</p>
            <p class="my-2 small"><i class="bi bi-clock"></i> 60 min</p>
        </div>
        <div class="d-flex justify-content-between border-top soft-text small py-2"><span>Bänkpress</span><span>4 set ·
                8 reps · 50 kg</span></div>
        <div class="d-flex justify-content-between border-top soft-text small py-2"><span>Marklyft</span><span>3 set · 5
                reps · 90 kg</span></div>
        <div class="d-flex justify-content-between border-top soft-text small py-2"><span>Knäböj</span><span>4 set · 6
                reps · 80 kg</span></div>
    </section>
</section>

    <div class="features d-flex flex-column gap-4">
    <div class="d-flex flex-wrap gap-3 align-items-start">
        <i class="bi bi-journal-plus feature-icon"></i>
        <div class="flex-260">
            <h3 class="fs-5 fw-bold mb-1">Logga dina pass</h3>
            <p class="text-muted mb-3">Skapa träningspass med valfritt antal övningar. Välj mellan styrka och kondition
                — appen anpassar fälten automatiskt.</p>

            <div class="col-11 col-md-6 mb-4 workout-card-col">
                <section class="card shadow-sm h-100 p-4">
                    <h2>Kondition</h2>
                    <div class="flex-grow-1">
                        <p class="my-1"><i class="bi bi-calendar3"></i> 10 mars 2026</p>
                        <p class="my-1"><i class="bi bi-clock"></i> 45 min</p>
                        <hr class="my-2">
                        <p class="my-1"><i class="bi bi-lightning-charge"></i> Löpning · 8,5 km</p>
                    </div>
                </section>
            </div>
        </div>
    </div>


    <div class="features d-flex flex-column gap-4">
        <div class="d-flex flex-wrap gap-3 align-items-start">
            <i class="bi bi-funnel feature-icon"></i>
            <div class="flex-260">
                <h3 class="fs-5 fw-bold mb-1">Filtrera och hitta</h3>
                <p class="text-muted mb-3">Sortera dina pass efter månad eller träningstyp. Bläddra enkelt bland
                    historiken
                    med inbyggd paginering.</p>

                <div class="col-11 col-md-6 mb-4 workout-card-col">
                    <section class="card shadow-sm h-100 p-4">
                        <h2>Kondition</h2>
                        <div class="d-flex flex-wrap gap-1 align-items-start">
                            <div class="filter-chip col-4 d-flex justify-content-between">
                                Styrketräning <i class="bi bi-caret-down-fill"></i>
                            </div>
                            <div class="filter-chip col-4 d-flex justify-content-between">
                                Mars <i class="bi bi-caret-down-fill"></i>
                            </div>
                            <div class="col-auto">
                                <div class="filter-chip active">Filtrera</div>
                            </div>
                        </div>
                        <div class="small mt-2">
                            Visar 6 pass
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-3 align-items-start">
        <i class="bi bi-graph-up-arrow feature-icon"></i>
        <div style="flex: 1 1 260px">
            <h3 class="fs-5 fw-bold mb-1">Följ din utveckling</h3>
            <p class="text-muted mb-3">Se hur du presterar över tid för varje övning. Filtrera på kategori och välj
                övning för att se din progression.</p>

            <div class="card col-11 mb-2 shadow-sm p-3">
                <h4 class="fs-5 mb-0">Benpress</h4>
                <p class="text-muted small mb-1">3 tillfällen loggade</p>
                <div class="card p-2 mb-2">
                    <div class="fw-semibold">10 mars 2026</div>
                    <small class="text-muted">15 reps · 100 kg</small>
                </div>
                <div class="card p-2 mb-2">
                    <div class="fw-semibold">3 mars 2026</div>
                    <small class="text-muted">12 reps ·  95 kg</small>
                </div>
                <div class="card p-2 mb-2">
                    <div class="fw-semibold">24 februari 2026</div>
                    <small class="text-muted">8 reps · 95 kg</small>
                </div>
            </div>
        </div>
    </div>


</div>

    @* Bottom CTA *@
    <div class="text-center py-5 mt-2 border-top">
    <h2 class="fw-bold mb-2">Redo att börja?</h2>
    <p class="text-muted mb-4">Skapa ett gratis konto och logga ditt första pass på under en minut.</p>
    <a class="btn btn-primary btn-lg px-5" asp-area="Identity" asp-page="/Account/Register">Registrera dig</a>
</div>
}
