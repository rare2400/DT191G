@model IEnumerable<WorkoutTracker.Models.ExerciseModel>

@{
    ViewData["Title"] = "Övningar";
}
<div>
    <h1 class="text-center">Övningar</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm">Lägg till övning</a>
</div>

<form asp-action="Index" method="get" class="d-flex mt-2">
    <select name="categoryId" asp-items="ViewBag.Categories" class="form-select me-2">
        <option value="">Välj kategori</option>
    </select>

    <button type="submit" class="btn btn-outline-dark">
        Filtrera
    </button>
</form>
@foreach (var item in Model)
{
    <div class="card my-2">
        <div class="card-body py-2 d-flex justify-content-between align-items-center">
            <div>
                <div class="fw-semibold">@item.Name</div>
                <small class="text-muted">@item.Category?.Name</small>
            </div>
            <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Ändra</a>
            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Ta bort</a>
            </div>
        </div>
    </div>
}
